# GEMINI_API_KEY: Optional fallback for Gemini AI API calls.
# DEPRECATED: The app now uses per-user Google OAuth tokens via Firebase Auth + Google Sign-In.
# Each user consumes their own Gemini quota — no shared API key needed.
# Keep this key only as a fallback if you need to bypass Google Sign-In for testing.
# Remove this line in production builds once Google Sign-In is fully validated.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# CDN_SIGNING_PRIVATE_KEY: Private key for signing video streaming URLs.
# Used by VideoSecurityService to generate HMAC-like signed tickets for CDN video access.
# In production, use a strong random key (e.g. 64+ hex chars) and keep it secret.
# NEVER commit the real production key to version control.
CDN_SIGNING_PRIVATE_KEY=violin_master_dev_signing_key_2026
