<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup rules for API 23–30 (fullBackupContent).

  Security-first: the Room database contains PIN hashes, security questions,
  personal messages, and user data — none of this should ever leave the device.

  SharedPreferences "app_settings" is excluded from cloud backup because it
  contains auth session tokens (current_user_id, google_signed_in). It is
  allowed in device-to-device transfer for user convenience (language,
  instrument preferences are harmless on a new device since auth tokens
  are device-specific and won't be valid).

  REQ-BACKUP-001: Exclude Room database from all backup.
  REQ-BACKUP-002: Exclude auth SharedPreferences from cloud backup.
-->
<full-backup-content>
    <!--
      Exclude the entire Room database. Contains:
      - UserAccount (PIN hashes, security question answers, birth year)
      - CachedMessage (private chat messages)
      - Assignment (teacher-student assignments)
      - PracticeSession, LessonProgress (practice history — backed up in Firestore)
    -->
    <exclude domain="database" path="violin_master_database" />

    <!--
      SharedPreferences "app_settings" is excluded from cloud backup but
      included in device transfer (see data_extraction_rules.xml for API 31+).
    -->
    <exclude domain="sharedpref" path="app_settings.xml" />

    <!--
      Exclude internal files that may contain cached sensitive data.
      Firebase, Crashlytics, and OkHttp caches live under /files.
    -->
    <exclude domain="file" path="." />
</full-backup-content>
